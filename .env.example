# ─── Database ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/nyxara?retryWrites=true&w=majority
MONGODB_DB=nyxara

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=8h

# ─── Service URLs (internal) ────────────────────────────────
AI_ENGINE_URL=http://localhost:8001
CYBER_ENGINE_URL=http://localhost:8002
BLOCKCHAIN_URL=http://localhost:8003

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# OR Upstash free cloud:
# REDIS_URL=rediss://:password@host.upstash.io:6379

# ─── Groq (LLM narration) ────────────────────────────────────
# Free API key at https://console.groq.com
# Leave blank to use rule-based fallback narrator (already coded)
GROQ_API_KEY=

# ─── Dataset ────────────────────────────────────────────────
DATASET_PATH=../data/dataset.xlsx

# ─── AI Engine tuning ────────────────────────────────────────
RISK_THRESHOLD_APPROVE=0.40
RISK_THRESHOLD_REVIEW=0.70
RISK_THRESHOLD_FLAG=0.85
# Weights must sum to 1.0
WEIGHT_GNN=0.35
WEIGHT_ENSEMBLE=0.25
WEIGHT_VAE=0.20
WEIGHT_BEI=0.12
WEIGHT_GRAPH=0.08

# ─── Ports ───────────────────────────────────────────────────
AI_ENGINE_PORT=8001
CYBER_ENGINE_PORT=8002
BLOCKCHAIN_PORT=8003
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ─── Node env ────────────────────────────────────────────────
NODE_ENV=development